# Ayrı Postgres (Yekpare DB ile aynı olmamalı) — Railway Postgres linkinden gelir
DATABASE_URL=postgresql://user:pass@host:5432/haber_merkezi

# Railway genelde PORT verir; yoksa 3100
PORT=3100
LISTEN_HOST=0.0.0.0

NODE_ENV=production

# Yekpare (sunucu) Bearer ile erişim: etiket:gizli (virgülle çoklu)
OPERATOR_API_KEYS=yekpare:degistir-bu-gizli-anahtari
