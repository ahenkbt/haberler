RewriteEngine on

RewriteRule ^index.html$ index.php [L,NC]
RewriteRule ^giris.html$ giris.php [L,NC]
RewriteRule ^([a-zA-Z0-9\-_]+).html$ index.php?sayfa=$1 [L,QSA]
