APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Üretimde kesinlikle false
APP_DEBUG=true
APP_URL=http://localhost

# Ana vitrin domain’i (www’süz); web.php route domain grubu için
WEBSITE_HOST=localhost

# Cron URL’leri (/subcheck, /check-payment, /expired …) için zorunlu paylaşılan sır (uzun rastgele)
CRON_SECRET=

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# HTTPS üretimde true; oturum çerezini yalnız TLS’te gönderir
SESSION_SECURE_COOKIE=false
# lax | strict | none
SESSION_SAME_SITE=lax

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

TIMEZONE=
