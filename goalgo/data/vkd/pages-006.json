{"pageUpdates":[{"id":"wp-template-contact","title":"Contact","slug":"contact","bodyHtml":"<div class=\"hm-vkd-page-root\">\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800&amp;family=Merriweather:ital,wght@0,400;0,700;1,400&amp;display=swap\">\n<style>.hm-vkd-page-root, .hm-custom-page-body {\n  --r:#8C1A2E;--rd:#6E1222;--rl:rgba(140,26,46,.09);\n  --g:#C9A84C;--gl:rgba(201,168,76,.1);\n  --dk:#0D1117;--dk2:#1C2330;--wh:#FAFAF8;\n  --gr:#F5F2ED;--bd:#E4E0D8;\n  --t1:#1A1F28;--t2:#4A5568;--t3:#718096;\n  --fn:'Nunito Sans',system-ui,sans-serif;\n  --fs:'Merriweather',Georgia,serif;\n  --w:1440px;\n}</style>\n\n\n<style>#content,#MainContent,main#content{max-width:100%!important;padding:0!important;width:100%!important;margin:0!important}\n.page-hero,.page-content,.page__heading,.page__header,.page-header,.page-title{display:none!important}</style>\n\n<div class=\"pw\">\n<div class=\"ph\">\n  <div class=\"ph-w\">\n    <div>\n      <div class=\"lang-sw\">\n        <a href=\"/iletisim\">🇹🇷 Türkçe</a>\n        <a href=\"/contact\" class=\"on\">🇬🇧 English</a>\n      </div>\n      <div class=\"ph-ew\">📩 Contact Us</div>\n      <h1 class=\"ph-h1\">We're Here<em>for You</em></h1>\n      <p class=\"ph-desc\">Whether you're a veteran seeking support, a donor wanting to contribute, or a partner interested in collaboration — <strong>we're here for you.</strong> Our team responds within 24 hours.</p>\n    </div>\n    <div class=\"ph-cinfo\">\n      <div class=\"ph-ci\"><div class=\"ph-ci-icon\">📞</div><div><div class=\"ph-ci-lbl\">Phone (Veteran Helpline)</div><div class=\"ph-ci-val\"><a href=\"tel:+903129630795\">+90 312 963 07 95</a></div></div></div>\n      <div class=\"ph-ci\"><div class=\"ph-ci-icon\">✉️</div><div><div class=\"ph-ci-lbl\">E-mail</div><div class=\"ph-ci-val\"><a href=\"mailto:vakif@vatankahramanlari.org\">vakif@vatankahramanlari.org</a></div></div></div>\n      <div class=\"ph-ci\"><div class=\"ph-ci-icon\">🌐</div><div><div class=\"ph-ci-lbl\">Website</div><div class=\"ph-ci-val\"><a href=\"https://vatankahramanlari.org\">vatankahramanlari.org</a></div></div></div>\n      <div class=\"ph-ci\"><div class=\"ph-ci-icon\">📍</div><div><div class=\"ph-ci-lbl\">Headquarters</div><div class=\"ph-ci-val\">Karanfil Sokak 4/91, Çankaya, Ankara</div></div></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"qc-sec\">\n  <div class=\"qc-w\">\n    <div class=\"qc-item\"><div class=\"qc-icon\">📞</div><div><div class=\"qc-lbl\">Veteran Helpline</div><div class=\"qc-val\"><a href=\"tel:+903129630795\">+90 312 963 07 95</a></div></div></div>\n    <div class=\"qc-item\"><div class=\"qc-icon\">✉️</div><div><div class=\"qc-lbl\">E-mail</div><div class=\"qc-val\"><a href=\"mailto:vakif@vatankahramanlari.org\">vakif@vatankahramanlari.org</a></div></div></div>\n    <div class=\"qc-item\"><div class=\"qc-icon\">💝</div><div><div class=\"qc-lbl\">Donations</div><div class=\"qc-val\"><a href=\"/donation\">vatankahramanlari.org/pages/donation</a></div></div></div>\n    <div class=\"qc-item\"><div class=\"qc-icon\">🤝</div><div><div class=\"qc-lbl\">Partnership</div><div class=\"qc-val\"><a href=\"/isbirligi\">Cooperation Programs</a></div></div></div>\n  </div>\n</div>\n\n<div class=\"of-sec\">\n  <div style=\"margin-bottom:4px;font-size:8.5px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--r)\">📍 Our Offices</div>\n  <div style=\"font-family:var(--fs);font-size:1.4rem;font-weight:700;color:var(--t1)\">5 Offices · 4 Continents</div>\n  <div class=\"of-grid\">\n    <div class=\"of-card\"><div class=\"of-flag\">🇹🇷</div><div class=\"of-city\">Ankara, Turkey</div><div class=\"of-name\">VATAN KAHRAMANLARI DERNEĞİ</div><div class=\"of-addr\">Meşrutiyet Mah. Karanfil Sokak 4/91, Çankaya</div></div>\n    <div class=\"of-card\"><div class=\"of-flag\">🇺🇸</div><div class=\"of-city\">Wyoming, USA</div><div class=\"of-name\">Heroes of the Homeland Foundation Inc.</div><div class=\"of-addr\">1621 Central Ave, Cheyenne WY 82001</div></div>\n    <div class=\"of-card\"><div class=\"of-flag\">🇦🇿</div><div class=\"of-city\">Baku, Azerbaijan</div><div class=\"of-name\">International Veterans Organization MMC</div><div class=\"of-addr\">Caferov Qardaşları No: 19, İçerişeher</div></div>\n    <div class=\"of-card\"><div class=\"of-flag\">🇬🇧</div><div class=\"of-city\">London, UK</div><div class=\"of-name\">Vatan Social Services</div><div class=\"of-addr\">71-75 Shelton Street, Covent Garden WC2H 9JQ</div></div>\n    <div class=\"of-card\"><div class=\"of-flag\">🇬🇪</div><div class=\"of-city\">Batumi, Georgia</div><div class=\"of-name\">VKV Batumi Representative</div><div class=\"of-addr\">Kutaisi Street No: 1, Old Batumi</div></div>\n  </div>\n</div>\n\n<div class=\"fm-sec\">\n  <div class=\"fm-w\">\n    <div>\n      <div class=\"fm-box\">\n        <div class=\"fm-head\"><div class=\"fm-head-icon\">✉️</div><div><h3>Send a Message</h3><p>We will respond within 24 hours</p></div></div>\n        <div class=\"fm-body\">\n          <div class=\"fg-row\">\n            <div class=\"fg\"><label>Full Name *</label><input type=\"text\" placeholder=\"Your Name Surname\"></div>\n            <div class=\"fg\"><label>E-mail *</label><input type=\"email\" placeholder=\"example@mail.com\"></div>\n          </div>\n          <div class=\"fg-row\">\n            <div class=\"fg\"><label>Phone</label><input type=\"tel\" placeholder=\"+1 ___ ___ __ __\"></div>\n            <div class=\"fg\"><label>Subject *</label>\n              <select>\n                <option value>Select...</option>\n                <option>Veteran Support</option>\n                <option>Donation</option>\n                <option>Scholarship Application</option>\n                <option>Partnership Proposal</option>\n                <option>Media & Press</option>\n                <option>General Information</option>\n              </select>\n            </div>\n          </div>\n          <div class=\"fg\"><label>Your Message *</label><textarea rows=\"5\" placeholder=\"Please explain your request...\"></textarea></div>\n          <button class=\"fg-submit\" type=\"button\">{this.textContent='Send →';this.style.background='#8C1A2E'},3000)\">Send →</button>\n        </div>\n      </div>\n    </div>\n    <div style=\"display:flex;flex-direction:column;gap:16px\">\n      <div class=\"map-box\">\n        \n        <div class=\"map-info\"><div class=\"map-addr\"><strong>Ankara Headquarters</strong>Meşrutiyet Mah. Karanfil Sokak 4/91, Çankaya / Ankara</div></div>\n      </div>\n      <div style=\"background:#fff;border:1px solid var(--bd);border-radius:8px;padding:20px 22px\">\n        <div style=\"font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--r);margin-bottom:12px\">Working Hours</div>\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:12px;color:var(--t2)\">\n          <div>Monday – Friday</div><div style=\"font-weight:700;color:var(--t1)\">09:00 – 18:00</div>\n          <div>Saturday</div><div style=\"font-weight:700;color:var(--t1)\">10:00 – 14:00</div>\n          <div>Sunday</div><div style=\"color:var(--t3)\">Closed</div>\n        </div>\n        <div style=\"margin-top:14px;padding-top:14px;border-top:1px solid var(--bd);font-size:11.5px;color:var(--t2)\">🔴 <strong style=\"color:var(--t1)\">Veteran Helpline</strong> — available 7/24 for urgent needs</div>\n      </div>\n    </div>\n  </div>\n</div>\n</div>\n</div>","enabled":true,"fullWidth":false,"importSource":"wordpress-template","sourceName":"page-contact.php","importedAt":"2026-05-22T18:04:21.011Z"},{"id":"wp-template-donation","title":"Donation","slug":"donation","bodyHtml":"<div class=\"hm-vkd-page-root\">\n<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800&amp;family=Merriweather:ital,wght@0,400;0,700;1,400&amp;display=swap\">\n<style>.hm-vkd-page-root, .hm-custom-page-body {--r:#8C1A2E;--rd:#6E1222;--rl:rgba(140,26,46,.09);--g:#C9A84C;--gl:rgba(201,168,76,.1);--dk:#0D1117;--dk2:#1C2330;--wh:#FAFAF8;--gr:#F5F2ED;--bd:#E4E0D8;--t1:#1A1F28;--t2:#4A5568;--t3:#718096;--fn:'Nunito Sans',system-ui,sans-serif;--fs:'Merriweather',Georgia,serif;--w:1440px}\n#content,main#content{max-width:100%!important;padding:0!important;width:100%!important;margin:0!important}\n.pw{font-family:var(--fn);background:var(--wh);color:var(--t1)}\n.ph{width:100%;background:linear-gradient(150deg,var(--dk) 0%,var(--dk2) 55%,#18060a 100%);padding:72px 40px 60px;position:relative;overflow:hidden}\n.ph-w{max-width:var(--w);margin:0 auto;display:grid;grid-template-columns:1.3fr 1fr;gap:60px;align-items:center;position:relative;z-index:1}\n.ph-ew{display:inline-flex;align-items:center;gap:7px;background:rgba(201,168,76,.12);border:1px solid rgba(201,168,76,.3);color:var(--g);font-size:9.5px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;padding:6px 14px;border-radius:20px;margin-bottom:18px}\n.ph-h1{font-family:var(--fs);font-size:clamp(1.8rem,3vw,2.8rem);font-weight:700;color:#fff;line-height:1.15;margin-bottom:14px}\n.ph-h1 em{color:var(--g);font-style:italic;display:block}\n.ph-desc{font-size:13.5px;color:rgba(255,255,255,.5);line-height:1.85;max-width:500px}\n.bw{background:#fff;border-radius:10px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.3)}\n.bw-head{background:linear-gradient(135deg,var(--r),var(--rd));padding:22px 26px;color:#fff}\n.bw-head h3{font-family:var(--fs);font-size:1.15rem;font-weight:700;margin-bottom:4px}\n.bw-body{padding:24px 26px}\n.bw-amts{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}\n.bw-amt{padding:10px 6px;border:1.5px solid var(--bd);border-radius:6px;font-size:12.5px;font-weight:700;color:var(--t2);background:var(--gr);cursor:pointer;text-align:center;transition:0.2s}\n.bw-amt.on,.bw-amt:hover{background:var(--r);border-color:var(--r);color:#fff}\n.bw-go{display:block;width:100%;background:var(--r);color:#fff;border:none;border-radius:6px;padding:15px;font-size:14px;font-weight:700;cursor:pointer;transition:0.2s}\n.bw-go:hover{background:var(--rd)}\n\n\n.sec{width:100%;padding:60px 40px}.sec:nth-child(even){background:var(--gr)}\n.sec-w{max-width:var(--w);margin:0 auto}\n.sec-hd{margin-bottom:30px;padding-bottom:16px;border-bottom:2px solid var(--bd)}\n.sec-title{font-family:var(--fs);font-size:1.8rem;font-weight:700;color:var(--t1);margin-bottom:8px}\n.sec-sub{font-size:14px;color:var(--t3);line-height:1.7;max-width:800px}\n.badge.r{background:var(--rl);color:var(--r);border:1px solid rgba(140,26,46,.2);padding:4px 12px;border-radius:20px;font-size:10px;font-weight:800;text-transform:uppercase;margin-bottom:10px;display:inline-block}\n.badge.g{background:var(--gl);color:#7a5a00;border:1px solid rgba(201,168,76,.3);padding:4px 12px;border-radius:20px;font-size:10px;font-weight:800;text-transform:uppercase;margin-bottom:10px;display:inline-block}\n\n.info-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}\n.info-card{background:#fff;border:1px solid var(--bd);border-radius:12px;padding:30px 22px;text-align:center;transition:0.3s;position:relative;overflow:hidden}\n.info-card:hover{transform:translateY(-5px);box-shadow:0 10px 25px rgba(0,0,0,0.05);border-color:var(--g)}\n.info-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--r),var(--g))}\n.info-icon{font-size:2.5rem;margin-bottom:15px;display:block}\n.info-title{font-family:var(--fs);font-size:1.05rem;font-weight:700;color:var(--t1);margin-bottom:10px}\n.info-desc{font-size:12.5px;color:var(--t2);line-height:1.7}\n\n@media(max-width:1024px){.info-grid{grid-template-columns:repeat(2,1fr)}}\n@media(max-width:600px){.ph-w,.info-grid{grid-template-columns:1fr}}</style>\n\n<div class=\"pw\">\n    <div class=\"ph\">\n        <div class=\"ph-w\">\n            <div>\n                <div class=\"ph-ew\">💝 Global Support · 100% Transparent</div>\n                <h1 class=\"ph-h1\">Support Our Heroes<em>Secure Donation</em></h1>\n                <p class=\"ph-desc\">Your contributions go <strong>directly to prosthetics, rehabilitation, and education</strong> for war veterans and terror victims. Management expenses are never covered by donations.</p>\n            </div>\n            <div>\n                <div class=\"bw\">\n                    <div class=\"bw-head\">\n                        <h3>Donate in USD</h3>\n                        <p>Global support for heroes of the homeland</p>\n                    </div>\n                    <div class=\"bw-body\">\n                        <div class=\"bw-amts\" id=\"usd-selector\">\n                            <button class=\"bw-amt\" data-val=\"25\" type=\"button\">$25</button>\n                            <button class=\"bw-amt\" data-val=\"50\" type=\"button\">$50</button>\n                            <button class=\"bw-amt on\" data-val=\"100\" type=\"button\">$100</button>\n                            <button class=\"bw-amt\" data-val=\"250\" type=\"button\">$250</button>\n                            <button class=\"bw-amt\" data-val=\"500\" type=\"button\">$500</button>\n                            <button class=\"bw-amt\" data-val=\"1000\" type=\"button\">$1000</button>\n                        </div>\n                        <input type=\"number\" id=\"custom-usd\" class=\"bw-inp\" placeholder=\"Custom USD Amount\" style=\"width:100%; border:1px solid var(--bd); padding:12px; border-radius:6px; margin-bottom:15px; outline:none;\">\n                        <button class=\"bw-go\" type=\"button\">💝 Continue to Stripe →</button>\n                        <div style=\"text-align:center; font-size:10px; color:var(--t3); margin-top:12px;\">🔒 SSL Secured by Stripe</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"sec\">\n        <div class=\"sec-w\">\n            <div class=\"sec-hd\">\n                <div class=\"badge r\">💪 Impact of Your Donation</div>\n                <h2 class=\"sec-title\">What Does Your Support Provide?</h2>\n                <p class=\"sec-sub\">Our foundation dedicates all its resources primarily to serving Turkey and the Turkic world.</p>\n            </div>\n            <div class=\"info-grid\">\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">🦾</span>\n                    <h4 class=\"info-title\">Prosthetics & Rehabilitation</h4>\n                    <p class=\"info-desc\">Enables veterans, war and terror victims, and disabled people in the Turkic world to move independently.</p>\n                </div>\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">🧠</span>\n                    <h4 class=\"info-title\">Psychological Empowerment</h4>\n                    <p class=\"info-desc\">Contributes to psychological and social empowerment, helping beneficiaries look at life with more hope.</p>\n                </div>\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">🎓</span>\n                    <h4 class=\"info-title\">Education & Scholarships</h4>\n                    <p class=\"info-desc\">Supports scholarship and mentoring programs that strengthen the educational lives of martyrs' and veterans' children.</p>\n                </div>\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">🌍</span>\n                    <h4 class=\"info-title\">13 Countries · 5 Continents</h4>\n                    <p class=\"info-desc\">Reaches our brothers and sisters from Azerbaijan to Pakistan, from Bosnia to Kosovo across the globe.</p>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"sec\">\n        <div class=\"sec-w\">\n            <div class=\"sec-hd\">\n                <div class=\"badge g\">📊 Transparency & Accountability</div>\n                <h2 class=\"sec-title\">You Know Where Your Money Goes</h2>\n            </div>\n            <div class=\"info-grid\">\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">🤲</span>\n                    <h4 class=\"info-title\">Volunteer Management</h4>\n                    <p class=\"info-desc\">Our directors and officials serve without any compensation on a voluntary basis. Every cent goes to those in need.</p>\n                </div>\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">📋</span>\n                    <h4 class=\"info-title\">Annual Activity Report</h4>\n                    <p class=\"info-desc\">Transparent activity reports shared with the public annually, with all income and expense items detailed.</p>\n                </div>\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">🔒</span>\n                    <h4 class=\"info-title\">Secure Payment</h4>\n                    <p class=\"info-desc\">Donations are processed securely with Stripe infrastructure, SSL 256-bit encryption and 3D Secure technology.</p>\n                </div>\n                <div class=\"info-card\">\n                    <span class=\"info-icon\">🌐</span>\n                    <h4 class=\"info-title\">International Audit</h4>\n                    <p class=\"info-desc\">As a 501(c)(3), we report to US federal tax authorities and are audited to international standards.</p>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n</div>","enabled":true,"fullWidth":false,"importSource":"wordpress-template","sourceName":"page-donation.php","importedAt":"2026-05-22T18:04:21.013Z"}]}