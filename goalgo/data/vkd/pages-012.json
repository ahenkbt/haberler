\n        </div>\n\n        <div class=\"kurum-section\" data-cat=\"uluslararasi\">\n            <div class=\"kurum-sec-head\">\n                <h2>Uluslararası Kuruluşlar</h2>\n                <span class=\"count\">13 KURULUŞ</span>\n            </div>\n            <div class=\"kurum-grid\">\n                <a href=\"https://www.who.int\" target=\"_blank\" class=\"kurum-card\" data-n=\"WHO Dünya Sağlık Örgütü World Health Organization\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">🏥</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">WHO (Dünya Sağlık Örgütü)</span><span class=\"kurum-desc\">who.int</span></div>\n                    <i class=\"fa-solid fa-arrow-up-right-from-square k-link-icon\"></i>\n                </a>\n                <a href=\"https://unhabitat.org\" target=\"_blank\" class=\"kurum-card\" data-n=\"UN-HABITAT BM İnsan Yerleşimleri Programı\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">🏙️</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">UN-HABITAT</span><span class=\"kurum-desc\">unhabitat.org</span></div>\n                    <i class=\"fa-solid fa-arrow-up-right-from-square k-link-icon\"></i>\n                </a>\n                <a href=\"https://www.oic-oci.org\" target=\"_blank\" class=\"kurum-card\" data-n=\"OIC İİT İslam İşbirliği Teşkilatı\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">☪️</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">OIC / İİT (İslam İşbirliği)</span><span class=\"kurum-desc\">oic-oci.org</span></div>\n                    <i class=\"fa-solid fa-arrow-up-right-from-square k-link-icon\"></i>\n                </a>\n                <a href=\"https://www.eco.int\" target=\"_blank\" class=\"kurum-card\" data-n=\"ECO EİT Ekonomik İşbirliği Teşkilatı\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">📈</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">ECO / EİT (Ekonomik İşbirliği)</span><span class=\"kurum-desc\">eco.int</span></div>\n                    <i class=\"fa-solid fa-arrow-up-right-from-square k-link-icon\"></i>\n                </a>\n                <a href=\"https://www.osce.org\" target=\"_blank\" class=\"kurum-card\" data-n=\"OSCE AGİT Avrupa Güvenlik İşbirliği Teşkilatı\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">🕊️</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">OSCE / AGİT</span><span class=\"kurum-desc\">osce.org</span></div>\n                    <i class=\"fa-solid fa-arrow-up-right-from-square k-link-icon\"></i>\n                </a>\n                <a href=\"https://www.unossc.org\" target=\"_blank\" class=\"kurum-card\" data-n=\"UNOSSC BM Güney Güney İşbirliği Ofisi\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">🌍</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">UNOSSC</span><span class=\"kurum-desc\">unossc.org</span></div>\n                    <i class=\"fa-solid fa-arrow-up-right-from-square k-link-icon\"></i>\n                </a>\n                <a href=\"https://www.unaoc.org\" target=\"_blank\" class=\"kurum-card\" data-n=\"UNAOC BM Medeniyetler İttifakı\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">🤝</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">UNAOC</span><span class=\"kurum-desc\">unaoc.org</span></div>\n                    <i class=\"fa-solid fa-arrow-up-right-from-square k-link-icon\"></i>\n                </a>\n                <a href=\"https://www.unwto.org\" target=\"_blank\" class=\"kurum-card\" data-n=\"UNWTO Dünya Turizm Örgütü\" rel=\"noopener noreferrer\">\n                    <div class=\"kurum-emblem\">✈️</div>\n                    <div class=\"kurum-info\"><span class=\"kurum-name\">UNWTO (Dünya