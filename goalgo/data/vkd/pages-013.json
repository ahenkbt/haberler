{"pageUpdates":[{"id":"wp-template-rss-panel","title":"RSS Haberler","slug":"rss-panel","bodyHtml":"<div class=\"hm-vkd-page-root\">\n<style>.hm-vkd-page-root, .hm-custom-page-body {\n  --r:#8C1A2E;--rd:#6E1222;--rl:rgba(140,26,46,.09);\n  --g:#C9A84C;--gl:rgba(201,168,76,.1);\n  --dk:#0D1117;--dk2:#1C2330;--wh:#FAFAF8;\n  --gr:#F5F2ED;--bd:#E4E0D8;\n  --t1:#1A1F28;--t2:#4A5568;--t3:#718096;\n  --fn:'Nunito Sans',system-ui,sans-serif;\n  --fs:'Merriweather',Georgia,serif;\n  --w:1440px;\n}</style>\n\n\n<style>#content,#MainContent,main#content{max-width:100%!important;padding:0!important;width:100%!important;margin:0!important}\n.page-hero,.page-content,.page__heading,.page__header,.page-header,.page-title{display:none!important}</style>\n<style>@import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800&display=swap');\n*{box-sizing:border-box}\n.rp{font-family:'Nunito Sans',system-ui,sans-serif;max-width:1000px;margin:0 auto;padding:32px 24px 60px;color:#1A1F28}\n.rp-hero{background:linear-gradient(135deg,#0D1117,#1C2330);border-radius:4px;padding:28px 32px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between}\n.rp-hero h1{font-size:1.5rem;font-weight:800;color:#fff;margin-bottom:4px}\n.rp-hero p{font-size:12.5px;color:rgba(255,255,255,.4)}\n.rp-add-btn{background:#8C1A2E;color:#fff;border:none;padding:11px 20px;border-radius:4px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;transition:background .2s}\n.rp-add-btn:hover{background:#6E1222}\n.rp-card{background:#fff;border:1px solid #EAE6DE;border-radius:4px;margin-bottom:12px;overflow:hidden}\n.rp-card-hd{padding:16px 20px;display:flex;align-items:center;gap:14px}\n.rp-card-icon{width:40px;height:40px;background:#F5F2ED;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}\n.rp-card-info{flex:1}\n.rp-card-title{font-size:14px;font-weight:700;color:#1A1F28;margin-bottom:3px}\n.rp-card-url{font-size:11.5px;color:#718096;word-break:break-all}\n.rp-card-cat{display:inline-block;background:#F5F2ED;border-radius:20px;padding:2px 10px;font-size:10px;font-weight:700;color:#4A5568;margin-top:4px}\n.rp-card-actions{display:flex;gap:8px;flex-shrink:0}\n.rp-btn-test{background:#F5F2ED;color:#4A5568;border:1px solid #EAE6DE;padding:8px 14px;border-radius:4px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:inherit;transition:all .2s}\n.rp-btn-test:hover{background:#EAE6DE}\n.rp-btn-del{background:#FFF5F5;color:#C53030;border:1px solid #FEB2B2;padding:8px 14px;border-radius:4px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:inherit;transition:all .2s}\n.rp-btn-del:hover{background:#FED7D7}\n.rp-badge-ok{background:#F0FFF4;color:#276749;border:1px solid #9AE6B4;padding:4px 10px;border-radius:20px;font-size:10px;font-weight:700}\n.rp-badge-err{background:#FFF5F5;color:#C53030;border:1px solid #FEB2B2;padding:4px 10px;border-radius:20px;font-size:10px;font-weight:700}\n\n\n.rp-modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;align-items:center;justify-content:center;padding:20px}\n.rp-modal-bg.open{display:flex}\n.rp-modal{background:#fff;border-radius:4px;max-width:520px;width:100%;animation:rpIn .3s ease}\n@keyframes rpIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}\n.rp-modal-hd{background:linear-gradient(135deg,#0D1117,#1C2330);padding:20px 24px;border-radius:4px 4px 0 0;display:flex;align-items:center;justify-content:space-between}\n.rp-modal-hd h2{font-size:1rem;font-weight:700;color:#fff}\n.rp-modal-close{background:none;border:none;color:rgba(255,255,255,.6);font-size:18px;cursor:pointer;line-height:1}\n.rp-modal-body{padding:24px}\n.rp-field{margin-bottom:16px}\n.rp-field label{display:block;font-size:12px;font-weight:700;color:#4A5568;margin-bottom:5px;letter-spacing:.3px}\n.rp-field input,.rp-field select{width:100%;padding:10px 13px;border:1px solid #EAE6DE;border-radius:4px;font-size:13px;font-family:inherit;color:#1A1F28;outline:none;transition:border .2s}\n.rp-field input:focus,.rp-field select:focus{border-color:#8C1A2E}\n.rp-field .hint{font-size:10.5px;color:#718096;margin-top:4px}\n.rp-save-btn{width:100%;background:#8C1A2E;color:#fff;border:none;padding:12px;border-radius:4px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;transition:background .2s;margin-top:4px}\n.rp-save-btn:hover{background:#6E1222}\n\n\n.rp-test-result{padding:12px 20px;background:#F5F2ED;border-top:1px solid #EAE6DE;font-size:12.5px;display:none}\n.rp-test-result.show{display:block}\n\n\n.rp-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}\n.rp-stat{background:#fff;border:1px solid #EAE6DE;border-radius:4px;padding:14px 16px}\n.rp-stat strong{display:block;font-size:1.4rem;font-weight:800;color:#8C1A2E}\n.rp-stat span{font-size:11px;color:#718096}\n\n.rp-empty{text-align:center;padding:48px 24px;color:#718096;background:#F5F2ED;border-radius:4px;border:2px dashed #EAE6DE}\n.rp-empty p{margin-bottom:16px;font-size:14px}</style>\n\n<div class=\"rp\">\n  <div class=\"rp-hero\">\n    <div>\n      <h1>📡 RSS Haber Yönetimi</h1>\n      <p>RSS feed'lerini ekle, yönet ve haberler sayfasını yapılandır</p>\n    </div>\n    <button class=\"rp-add-btn\" type=\"button\">+ Yeni RSS Feed Ekle</button>\n  </div>\n\n  \n  <div class=\"rp-stats\">\n    <div class=\"rp-stat\"><strong id=\"rp-stat-feeds\">0</strong><span>Aktif Feed</span></div>\n    <div class=\"rp-stat\"><strong id=\"rp-stat-items\">—</strong><span>Toplam Haber</span></div>\n    <div class=\"rp-stat\"><strong id=\"rp-stat-cats\">0</strong><span>Kategori</span></div>\n    <div class=\"rp-stat\"><strong id=\"rp-stat-last\">—</strong><span>Son Güncelleme</span></div>\n  </div>\n\n  \n  <div id=\"rp-list\"></div>\n\n  \n  <div style=\"background:#F5F2ED;border:1px solid #EAE6DE;border-radius:4px;padding:20px 24px;margin-top:20px\">\n    <div style=\"font-size:12px;font-weight:700;color:#4A5568;margin-bottom:12px;letter-spacing:.5px;text-transform:uppercase\">📋 Nasıl Kullanılır?</div>\n    <div style=\"font-size:12.5px;color:#718096;line-height:1.8\">\n      <p>1. <strong style=\"color:#1A1F28\">RSS Feed Ekle</strong> — Herhangi bir RSS URL'i ekleyin (haberler.com, BBC, CNN Türk vb.)</p>\n      <p>2. <strong style=\"color:#1A1F28\">Kategori Seç</strong> — Haberlerin hangi kategoride görüneceğini belirleyin</p>\n      <p>3. <strong style=\"color:#1A1F28\">Test Et</strong> — Feed'in çalışıp çalışmadığını kontrol edin</p>\n      <p>4. <strong style=\"color:#1A1F28\">Haberler Sayfası</strong> — <a href=\"/haberler\" style=\"color:#8C1A2E;font-weight:700\">vatankahramanlari.org/pages/haberler</a> adresinde kategorilere göre görünür</p>\n    </div>\n    <div style=\"margin-top:12px;padding-top:12px;border-top:1px solid #EAE6DE;font-size:11.5px;color:#718096\">\n      <strong style=\"color:#1A1F28\">Örnek RSS URL'leri:</strong><br>\n      haberler.com Şehit: <code style=\"background:#fff;padding:2px 6px;border-radius:2px;font-size:11px\">https://rss.haberler.com/RssNew.aspx?kategori=%C5%9Fehit</code><br>\n      haberler.com Gazi: <code style=\"background:#fff;padding:2px 6px;border-radius:2px;font-size:11px\">https://rss.haberler.com/konu.asp?konu=gaziler</code><br>\n      Herhangi WordPress: <code style=\"background:#fff;padding:2px 6px;border-radius:2px;font-size:11px\">https://siteniz.com/feed</code>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"rp-modal-bg\" id=\"rp-modal\">\n  <div class=\"rp-modal\">\n    <div class=\"rp-modal-hd\">\n      <h2>📡 Yeni RSS Feed Ekle</h2>\n      <button class=\"rp-modal-close\" type=\"button\">✕</button>\n    </div>\n    <div class=\"rp-modal-body\">\n      <div class=\"rp-field\">\n        <label>Feed Adı *</label>\n        <input type=\"text\" id=\"rp-name\" placeholder=\"örn: Şehit Haberleri\">\n      </div>\n      <div class=\"rp-field\">\n        <label>RSS URL *</label>\n        <input type=\"url\" id=\"rp-url\" placeholder=\"https://...\">\n        <div class=\"hint\">Feed URL'ini buraya yapıştırın</div>\n      </div>\n      <div class=\"rp-field\">\n        <label>Kategori *</label>\n        <select id=\"rp-cat\">\n          <option value=\"Şehit\">🕯️ Şehit</option>\n          <option value=\"Gazi\">🎖️ Gazi</option>\n          <option value=\"Mehmetçik\">🪖 Mehmetçik</option>\n          <option value=\"Milli Savunma\">🛡️ Milli Savunma</option>\n          <option value=\"Vatan Kahramanları\">🇹🇷 Vatan Kahramanları</option>\n          <option value=\"Genel\">📰 Genel</option>\n          <option value=\"Özel\">⭐ Özel</option>\n        </select>\n      </div>\n      <div class=\"rp-field\">\n        <label>İkon (emoji)</label>\n        <input type=\"text\" id=\"rp-icon\" placeholder=\"📰\" maxlength=\"4\">\n      </div>\n      <button class=\"rp-save-btn\" type=\"button\">✓ Feed'i Kaydet</button>\n    </div>\n  </div>\n</div>\n</div>","enabled":true,"fullWidth":false,"importSource":"wordpress-template","sourceName":"page-rss-panel.php","importedAt":"2026-05-22T18:04:21.054Z"},{"id":"wp-template-sehit-gazi-haklari","title":"Şehit-Gazi Hakları","slug":"sehit-gazi-haklari","bodyHtml":"<div class=\"hm-vkd-page-root\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n<style>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;500;600&display=swap');\n\n.hm-vkd-page-root, .hm-custom-page-body {\n    --v-red: #B22234; \n    --v-red-dark: #8B0000;\n    --v-gold: #D4AF37; \n    --v-gold-light: #F4E5B2;\n    --v-dark: #121212;\n    --v-dark-soft: #1E1E1E;\n    --v-text-main: #2D3436;\n    --v-text-muted: #636E72;\n    --v-bg-light: #F9FAFB;\n    --v-glass: rgba(255, 255, 255, 0.95);\n    --shadow-premium: 0 10px 30px rgba(0,0,0,0.08);\n}\n\n.sgr-portal { \n    font-family: 'Inter', sans-serif; \n    background: var(--v-bg-light); \n    color: var(--v-text-main); \n    line-height: 1.6;\n}\n\n\n.sgr-hero {\n    position: relative;\n    background: linear-gradient(135deg, rgba(18, 18, 18, 0.9), rgba(139, 0, 0, 0.7)), \n                url('https://images.unsplash.com/photo-1590234900693-80e793910543?q=80&w=2000');\n    background-size: cover; background-position: center;\n    padding: 120px 20px; text-align: center; color: #fff;\n    border-bottom: 5px solid var(--v-gold);\n}\n\n.sgr-hero-badge {\n    display: inline-block;\n    background: var(--v-gold);\n    color: #000;\n    padding: 6px 18px;\n    border-radius: 50px;\n    font-size: 12px;\n    font-weight: 800;\n    text-transform: uppercase;\n    margin-bottom: 20px;\n    letter-spacing: 2px;\n}\n\n.sgr-hero h1 { \n    font-family: 'Playfair Display', serif; \n    font-size: clamp(2.5rem, 6vw, 4rem); \n    margin-bottom: 20px; \n    font-weight: 900;\n    text-shadow: 2px 2px 10px rgba(0,0,0,0.3);\n}\n\n.sgr-hero p { \n    max-width: 900px; margin: 0 auto 35px; \n    font-size: 1.2rem; opacity: 0.9; font-weight: 300;\n}\n\n\n.sgr-nav-wrap { \n    position: sticky; top: 0; z-index: 1000; \n    background: var(--v-glass); \n    backdrop-filter: blur(10px);\n    border-bottom: 1px solid rgba(0,0,0,0.05); \n    box-shadow: var(--shadow-premium);\n}\n\n.sgr-nav { \n    display: flex; max-width: 1300px; margin: 0 auto; \n    overflow-x: auto; scrollbar-width: none;\n}\n\n.sgr-nav::-webkit-scrollbar { display: none; }\n\n.sgr-btn {\n    padding: 22px 30px; border: none; background: none; \n    font-weight: 700; font-size: 12px; color: var(--v-text-muted);\n    cursor: pointer; white-space: nowrap; text-transform: uppercase; \n    letter-spacing: 1.5px; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    border-bottom: 3px solid transparent;\n}\n\n.sgr-btn i { margin-right: 8px; font-size: 14px; }\n\n.sgr-btn:hover { color: var(--v-red); }\n\n.sgr-btn.active { \n    color: var(--v-red); \n    border-bottom-color: var(--v-red); \n    background: rgba(178, 34, 52, 0.05);\n}\n\n\n.sgr-container { max-width: 1300px; margin: 50px auto; padding: 0 25px; }\n\n.sgr-panel { display: none; animation: vPremiumFade 0.6s ease-out forwards; }\n.sgr-panel.active { display: block; }\n\n@keyframes vPremiumFade { \n    from { opacity: 0; transform: translateY(30px) scale(0.98); } \n    to { opacity: 1; transform: translateY(0) scale(1); } \n}\n\n\n.v-section-head { margin-bottom: 40px; border-left: 5px solid var(--v-red); padding-left: 20px; }\n.v-section-head h2 { font-family: 'Montserrat', sans-serif; font-weight: 800; color: var(--v-dark); margin: 0; font-size: 1.8rem; }\n.v-section-head p { color: var(--v-text-muted); margin: 5px 0 0; }\n\n\n.sgr-grid { \n    display: grid; \n    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); \n    gap: 25px; \n}\n\n.sgr-card {\n    background: #fff; \n    border: 1px solid #E5E7EB; \n    border-radius: 20px; \n    padding: 40px 30px;\n    text-decoration: none !important; \n    transition: all 0.4s; \n    display: flex; \n    flex-direction: column;\n    position: relative; \n    overflow: hidden;\n    box-shadow: 0 4px 6px rgba(0,0,0,0.02);\n}\n\n.sgr-card::before {\n    content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 0;\n    background: var(--v-red); transition: 0.4s;\n}\n\n.sgr-card:hover { \n    transform: translateY(-10px); \n    border-color: transparent; \n    box-shadow: 0 25px 50px rgba(0,0,0,0.1); \n}\n\n.sgr-card:hover::before { height: 100%; }\n\n.sgr-card i { \n    font-size: 40px; margin-bottom: 20px; color: var(--v-red); \n    background: rgba(178, 34, 52, 0.05); width: 70px; height: 70px;\n    display: flex; align-items: center; justify-content: center; border-radius: 15px;\n    transition: 0.4s;\n}\n\n.sgr-card:hover i { background: var(--v-red); color: #fff; transform: rotate(-5deg); }\n\n.sgr-card h3 { \n    font-family: 'Montserrat', sans-serif; font-size: 1.35rem; \n    color: var(--v-dark); margin-bottom: 15px; font-weight: 700; \n}\n\n.sgr-card p { \n    font-size: 14.5px; color: var(--v-text-muted); \n    line-height: 1.7; flex-grow: 1; margin-bottom: 25px; \n}\n\n.sgr-card-footer { \n    display: flex; align-items: center; justify-content: space-between; \n    padding-top: 20px; border-top: 1px solid #F3F4F6; \n}\n\n.sgr-card-link { \n    font-size: 12px; font-weight: 700; color: var(--v-red); \n    display: flex; align-items: center; gap: 5px;\n}\n\n.sgr-card-src { \n    font-size: 10px; background: #F3F4F6; padding: 5px 12px; \n    border-radius: 6px; color: var(--v-text-muted); font-weight: 600; \n}\n\n\n.sgr-alert { \n    background: var(--v-dark-soft); color: #fff; padding: 40px; \n    border-radius: 20px; margin-bottom: 40px; \n    background-image: linear-gradient(to right, rgba(212, 175, 55, 0.1), transparent);\n    border-left: 8px solid var(--v-gold); \n}\n\n.sgr-alert h4 { \n    color: var(--v-gold); margin-bottom: 15px; \n    font-family: 'Montserrat', sans-serif; font-size: 1.4rem; display: flex; align-items: center; gap: 10px;\n}\n\n\n.v-mevzuat-list {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px;\n}\n.v-mevzuat-item {\n    background: #fff; padding: 15px; border-radius: 10px; border: 1px solid #eee;\n    display: flex; align-items: center; gap: 15px; transition: 0.3s;\n}\n.v-mevzuat-item:hover { border-color: var(--v-gold); background: #FFFCF5; }\n\n\n.sgr-cta-box { \n    background: linear-gradient(135deg, var(--v-dark), #2c3e50); \n    color: #fff; padding: 80px 40px; text-align: center; border-radius: 30px; \n    margin-top: 80px; position: relative; overflow: hidden;\n    border-bottom: 10px solid var(--v-red);\n}\n\n.sgr-cta-box::after {\n    content: 'TR'; position: absolute; right: -20px; bottom: -20px;\n    font-size: 200px; font-weight: 900; opacity: 0.03;\n}\n\n.sgr-cta-box h2 { font-family: 'Playfair Display', serif; font-size: 2.5rem; margin-bottom: 20px; }\n\n.v-phone-card {\n    background: rgba(255,255,255,0.05); display: inline-flex; align-items: center;\n    padding: 20px 40px; border-radius: 100px; border: 1px solid rgba(255,255,255,0.1);\n    margin: 30px 0; transition: 0.3s;\n}\n\n.v-phone-card:hover { background: rgba(255,255,255,0.1); transform: scale(1.05); }\n\n.btn-vkv-premium { \n    display: inline-block; background: var(--v-gold); color: #000; \n    padding: 20px 50px; border-radius: 50px; text-decoration: none; \n    font-weight: 800; transition: 0.4s; text-transform: uppercase; letter-spacing: 1px;\n}\n\n.btn-vkv-premium:hover { background: #fff; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }\n\n@media (max-width: 992px) { .v-mevzuat-list { grid-template-columns: 1fr; } }\n@media (max-width: 768px) { \n    .sgr-grid { grid-template-columns: 1fr; } \n    .sgr-hero { padding: 80px 20px; }\n    .sgr-hero h1 { font-size: 2rem; }\n}</style>\n\n<div class=\"sgr-portal\">\n    <section class=\"sgr-hero\">\n        <div class=\"sgr-container\">\n            <span class=\"sgr-hero-badge\">RESMİ REHBER PORTALI</span>\n            <h1>🛡️ Şehit & Gazi Hakları Tam Rehberi</h1>\n            <p>T.C. Aile ve Sosyal Hizmetler Bakanlığı verileriyle güncellenmiş, kahramanlarımız ve emanetleri için hazırlanmış en kapsamlı yasal haklar dökümü.</p>\n            <div style=\"display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;\">\n                <span style=\"background: rgba(255,255,255,0.1); padding: 8px 15px; border-radius: 5px; font-size: 13px;\"><i class=\"fa fa-check-circle\"></i> Güncel Mevzuat</span>\n                <span style=\"background: rgba(255,255,255,0.1); padding: 8px 15px; border-radius: 5px; font-size: 13px;\"><i class=\"fa fa-check-circle\"></i> Resmi Başvuru Linkleri</span>\n                <span style=\"background: rgba(255,255,255,0.1); padding: 8px 15px; border-radius: 5px; font-size: 13px;\"><i class=\"fa fa-check-circle\"></i> 7/24 Destek Hattı</span>\n            </div>\n        </div>\n    </section>\n\n    <nav class=\"sgr-nav-wrap\">\n        <div class=\"sgr-nav\">\n            <button class=\"sgr-btn active\" type=\"button\"><i class=\"fa fa-wallet\"></i> Mali Haklar</button>\n            <button class=\"sgr-btn\" type=\"button\"><i class=\"fa fa-heartpulse\"></i> Sağlık</button>\n            <button class=\"sgr-btn\" type=\"button\"><i class=\"fa fa-graduation-cap\"></i> Eğitim & Askerlik</button>\n            <button class=\"sgr-btn\" type=\"button\"><i class=\"fa fa-users-gear\"></i> Sosyal Haklar</button>\n            <button class=\"sgr-btn\" type=\"button\"><i class=\"fa fa-medal\"></i> Muharip & Sivil</button>\n            <button class=\"sgr-btn\" type=\"button\"><i class=\"fa fa-star-and-crescent\"></i> 15 Temmuz</button>\n            <button class=\"sgr-btn\" type=\"button\"><i class=\"fa fa-gavel\"></i> Mevzuat & Sorgulama</button>\n        </div>\n    </nav>\n\n    <div class=\"sgr-container\">\n        \n        <div class=\"sgr-panel active\" id=\"p-mali\">\n            <div class=\"v-section-head\">\n                <h2>Ekonomik Destekler ve Maaş Hakları</h2>\n                <p>Şehit yakınları ve gazilerimize sağlanan düzenli ödeme ve tazminatlar.</p>\n            </div>\n            <div class=\"sgr-grid\">\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/maas-baglama/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-money-bill-transfer\"></i>\n                    <h3>Maaş Bağlama</h3>\n                    <p>Şehit yakınları ve gazilerimize SGK tarafından aylık bağlanması, başvuru süreçleri ve yasal esaslar.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/nakdi-tazminat/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-building-columns\"></i>\n                    <h3>Nakdi Tazminat</h3>\n                    <p>Güvenlik ve asayişin sağlanmasında şehit olanların hak sahipleri ile gazilere ödenen tek seferlik tazminat.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/faizsiz-konut-kredisi/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-house-chimney\"></i>\n                    <h3>Faizsiz Konut Kredisi</h3>\n                    <p>TOKİ aracılığıyla sağlanan 240 ay vadeli faizsiz konut kredisi kullanım şartları ve mülk edindirme hakları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/elektrik-ve-su-ucret-indirimi/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-bolt-lightning\"></i>\n                    <h3>Elektrik ve Su İndirimi</h3>\n                    <p>Elektrik ücretinde %40, su ücretinde %50'den az olmamak üzere belirlenen indirimli tarifeler.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/dogalgaz-indirimi/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-fire-flame-curved\"></i>\n                    <h3>Doğalgaz İndirimi</h3>\n                    <p>Şehit yakınları ve gaziler için doğalgaz kullanımında sağlanan indirimli tarife ve uygulama esasları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/ek-odeme-ve-egitim-ogretim-yardimi/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-circle-plus\"></i>\n                    <h3>Ek Ödeme Hakları</h3>\n                    <p>Maluliyet derecelerine göre her yıl ödenen ek ödemeler ve yıllık tütün ikramiyesi detayları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n            </div>\n        </div>\n\n        <div class=\"sgr-panel\" id=\"p-saglik\">\n            <div class=\"sgr-alert\">\n                <h4><i class=\"fa fa-shield-medical\"></i> Sağlık Uygulama Tebliği (SUT) Avantajları</h4>\n                <p>Harp malulleri ve terör gazileri tüm sağlık hizmetlerinde <strong>katılım payından muaftır.</strong> Diş tedavileri, protez ve tıbbi malzeme giderleri en üst devlet desteği ile karşılanır.</p>\n            </div>\n            <div class=\"sgr-grid\">\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/maluliyet-derecesi/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-notes-medical\"></i>\n                    <h3>Maluliyet Derecesi</h3>\n                    <p>Yaralanma derecesi ve maluliyet tespiti süreçleri ile rapor işlemleri hakkında rehber.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/malul-sayilmayanlar/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-circle-info\"></i>\n                    <h3>Malul Sayılmayanlar</h3>\n                    <p>Malul sayılmayacak derecede yaralananların hakları ve başvuru süreçleri.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/tup-bebek-uygulamalari/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-baby\"></i>\n                    <h3>Tüp Bebek Desteği</h3>\n                    <p>Gazilerimiz ve şehit yakınları için sağlanan tıbbi yardımcı üreme teknikleri desteği kapsamı.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n            </div>\n        </div>\n\n        <div class=\"sgr-panel\" id=\"p-egitim\">\n            <div class=\"sgr-grid\">\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/ogrenim/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-user-graduate\"></i>\n                    <h3>Öğrenim Hakları</h3>\n                    <p>KYK bursları, yurt önceliği ve ücretsiz öğrenim imkanları hakkında başvuru rehberi.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/ek-odeme-ve-egitim-ogretim-yardimi/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-book-open\"></i>\n                    <h3>Eğitim-Öğretim Yardımı</h3>\n                    <p>Şehit ve gazi çocuklarına her yıl eğitim öğretim yılı başında yapılan maddi yardımlar.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/askerlik-muafiyeti/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-shield-halved\"></i>\n                    <h3>Askerlik Muafiyeti</h3>\n                    <p>Şehit ve gazi kardeşleri ile çocukları için askerlik görevinden muafiyet şartları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n            </div>\n        </div>\n\n        <div class=\"sgr-panel\" id=\"p-sosyal\">\n            <div class=\"sgr-grid\">\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/is-hakki-uygulamalari/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-briefcase\"></i>\n                    <h3>İş Hakkı Uygulamaları</h3>\n                    <p>Şehit yakınları için 2, gaziler için 1 kişilik kamuda istihdam hakkı ve atama usulleri.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/ucretsiz-seyahat-hakki/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-id-card\"></i>\n                    <h3>Ücretsiz Seyahat</h3>\n                    <p>Şehir içi ve şehirler arası ulaşım, demiryolu ve denizyollarında ücretsiz seyahat kartı işlemleri.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/sosyal-haklar/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-city\"></i>\n                    <h3>Genel Sosyal Haklar</h3>\n                    <p>Emlak vergisi muafiyeti, kamu sosyal tesisleri ve diğer toplumsal destek kalemleri.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/madalya-temini/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-award\"></i>\n                    <h3>Madalya Temini</h3>\n                    <p>Devlet Övünç Madalyası ve İstiklal Madalyası temini ile şeref aylığı başvuru koşulları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/diger-sosyal-haklar/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-star\"></i>\n                    <h3>Diğer Sosyal Haklar</h3>\n                    <p>ÖTV muafiyetinden kira yardımına kadar tanınan diğer güncel sosyal haklar listesi.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n            </div>\n        </div>\n\n        <div class=\"sgr-panel\" id=\"p-muharip\">\n            <div class=\"sgr-grid\">\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/istiklal-savasi-kore-ve-kibris-gazileri-muharip-gaziler/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-trophy\"></i>\n                    <h3>Muharip Gaziler</h3>\n                    <p>İstiklal Savaşı, Kore ve Kıbrıs Barış Harekatı gazilerimize sağlanan özel şeref aylığı ve sosyal haklar.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/diger-sorular/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-users-line\"></i>\n                    <h3>Terör Mağduru Siviller</h3>\n                    <p>Terör eylemleri nedeniyle hayatını kaybeden veya engelli hale gelen sivil vatandaşlarımıza sağlanan haklar.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n            </div>\n        </div>\n\n        <div class=\"sgr-panel\" id=\"p-15temmuz\">\n            <div class=\"v-section-head\">\n                <h2>15 Temmuz Demokrasi ve Milli Birlik</h2>\n                <p>Darbe girişimi sırasında şehit olan ve gazi olan vatandaşlarımızın özel hakları.</p>\n            </div>\n            <div class=\"sgr-grid\">\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/15-temmuz-darbe-girisiminde-sehit-olanlar/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-flag\"></i>\n                    <h3>15 Temmuz Şehit Yakınları</h3>\n                    <p>15 Temmuz şehit yakınları için tanımlanan özel maaş, tazminat ve istihdam hakları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/15-temmuz-darbe-girisiminde-malul-olan-gaziler/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-kit-medical\"></i>\n                    <h3>15 Temmuz Malul Gaziler</h3>\n                    <p>15 Temmuz'da malul olan gazilerimize tanınan sağlık, mali ve sosyal hakların dökümü.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n                <a href=\"https://aile.tr/sss/sehit-yakinlari-ve-gazilere-yonelik-hizmetler-dairesi-baskanligi/15-temmuz-darbe-girisiminde-malul-sayilmayacak-derecede-yaralanan-gaziler/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-hand-holding-heart\"></i>\n                    <h3>15 Temmuz Yaralı Gaziler</h3>\n                    <p>Malul sayılmayacak derecede yaralanan 15 Temmuz gazilerimizin hakları ve sağlanan destekler.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Resmi Bilgi <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">aile.tr</span></div>\n                </a>\n            </div>\n        </div>\n\n        <div class=\"sgr-panel\" id=\"p-mevzuat\">\n            <div class=\"v-section-head\">\n                <h2>Mevzuat, Sorgulama ve SSS</h2>\n                <p>Resmi kanunlar ve online sorgulama ekranlarına hızlı erişim.</p>\n            </div>\n            <div class=\"sgr-grid\">\n                <a href=\"https://www.aile.tr/syggm/s-s-s/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-clipboard-question\"></i>\n                    <h3>Bakanlık SSS Arşivi</h3>\n                    <p>En çok sorulan 100+ sorunun bakanlık tarafından onaylanmış resmi yanıtları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Sorulara Git <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">Resmi</span></div>\n                </a>\n                <a href=\"https://www.turkiye.gov.tr/sosyal-guvenlik-kurumu\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-fingerprint\"></i>\n                    <h3>E-Devlet Sorgulama</h3>\n                    <p>Maaş, ücretsiz seyahat kartı ve istihdam hakkı sorgulama ekranları.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">E-Devlet Giriş <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">Sorgula</span></div>\n                </a>\n                <a href=\"https://www.sgk.gov.tr/\" target=\"_blank\" class=\"sgr-card\" rel=\"noopener noreferrer\">\n                    <i class=\"fa-solid fa-landmark-dome\"></i>\n                    <h3>SGK Emeklilik Hizmetleri</h3>\n                    <p>Vazife malullüğü ve aylık bağlama servisleri ile ilgili kurumsal detaylar.</p>\n                    <div class=\"sgr-card-footer\"><span class=\"sgr-card-link\">Kuruma Git <i class=\"fa fa-arrow-right\"></i></span><span class=\"sgr-card-src\">SGK</span></div>\n                </a>\n            </div>\n\n            <div style=\"margin-top: 50px;\">\n                <h3><i class=\"fa fa-book-scale\"></i> Temel Dayanak Mevzuatlar</h3>\n                <div class=\"v-mevzuat-list\">\n                    <div class=\"v-mevzuat-item\">\n                        <i class=\"fa fa-file-contract\" style=\"color: var(--v-red);\"></i>\n                        <div><strong>2330 Sayılı Kanun</strong><br><small>Nakdi Tazminat ve Aylık Bağlanması Hakkında</small></div>\n                    </div>\n                    <div class=\"v-mevzuat-item\">\n                        <i class=\"fa fa-file-contract\" style=\"color: var(--v-red);\"></i>\n                        <div><strong>3713 Sayılı Kanun</strong><br><small>Terörle Mücadele Kanunu Kapsamındaki Haklar</small></div>\n                    </div>\n                    <div class=\"v-mevzuat-item\">\n                        <i class=\"fa fa-file-contract\" style=\"color: var(--v-red);\"></i>\n                        <div><strong>5434 Sayılı Kanun</strong><br><small>T.C. Emekli Sandığı Kanunu (Vazife Malullüğü)</small></div>\n                    </div>\n                    <div class=\"v-mevzuat-item\">\n                        <i class=\"fa fa-file-contract\" style=\"color: var(--v-red);\"></i>\n                        <div><strong>1005 Sayılı Kanun</strong><br><small>Muharip Gazilere Şeref Aylığı Bağlanması</small></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <section class=\"sgr-cta-box\">\n            <div class=\"sgr-hero-badge\" style=\"background: var(--v-red); color:#fff;\">7/24 DANIŞMA HATTI</div>\n            <h2>Resmi İletişim Hattı</h2>\n            <p>Yasal haklarınız, başvurularınız ve her türlü destek talebiniz için Bakanlık uzmanlarına ulaşın.</p>\n            \n            <div class=\"v-phone-card\">\n                <i class=\"fa fa-phone-volume\" style=\"font-size: 30px; margin-right: 20px; color: var(--v-gold);\"></i>\n                <div style=\"text-align: left;\">\n                    <div style=\"font-size: 12px; opacity: 0.8; text-transform: uppercase;\">Sosyal Hizmet Merkezi</div>\n                    <div style=\"font-size: 32px; font-weight: 900; letter-spacing: 2px;\">ALO 183</div>\n                </div>\n            </div>\n\n            <br>\n            <a href=\"tel:183\" class=\"btn-vkv-premium\">Hemen Ücretsiz Ara</a>\n            <div style=\"margin-top: 25px; font-size: 13px; opacity: 0.6;\">T.C. Aile ve Sosyal Hizmetler Bakanlığı İletişim Merkezi</div>\n        </section>\n    </div>\n</div>\n</div>","enabled":true,"fullWidth":false,"importSource":"wordpress-template","sourceName":"page-sehit-gazi-haklari.php","importedAt":"2026-05-22T18:04:21.056Z"}]}