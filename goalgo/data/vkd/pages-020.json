{"pageUpdates":[{"id":"4962be26-3e2d-4a70-80aa-68c3615e0b44","title":"Genel Başkan","slug":"baskan","bodyHtml":"<div style=\"font-family: 'Inter', 'Nunito Sans', sans-serif; background-color: #F8FAFC; color: #1E293B; line-height: 1.6; width: 100%; box-sizing: border-box; padding-bottom: 80px;\">\n\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:wght@600;700;800&family=Playfair+Display:wght@700;900&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n\n  <section style=\"position: relative; background: linear-gradient(135deg, rgba(13, 17, 23, 0.96), rgba(140, 26, 46, 0.94)), url('https://images.unsplash.com/photo-1507679799987-c73779587ccf?q=80&w=2000') center/cover no-repeat; padding: 120px 20px; text-align: center; color: #fff; border-bottom: 5px solid #C9A84C; width: 100%; box-sizing: border-box;\">\n    <div style=\"max-width: 1200px; margin: 0 auto; width: 100%;\">\n      <span style=\"display: inline-block; background-color: #C9A84C; color: #0D1117; padding: 6px 20px; border-radius: 50px; font-size: 11px; font-weight: 800; text-transform: uppercase; margin-bottom: 25px; letter-spacing: 2px;\"><i class=\"fa fa-user-tie\"></i> VATAN KAHRAMANLARI</span>\n      <h1 style=\"font-family: 'Playfair Display', serif; font-size: 45px; margin-top: 0; margin-bottom: 25px; font-weight: 900; text-shadow: 2px 2px 10px rgba(0,0,0,0.4); line-height: 1.2;\">Genel Başkan <span style=\"color: #C9A84C; display: block; font-family: 'Montserrat', sans-serif; font-size: 28px; font-weight: 700; margin-top: 10px; letter-spacing: 1px;\">Mustafa ÖZDEMİR</span></h1>\n      <p style=\"max-width: 850px; margin: 0 auto 45px; font-size: 18px; opacity: 0.9; font-weight: 300; line-height: 1.7;\">Vatan Kahramanları Derneği Genel Başkanı Mustafa ÖZDEMİR'in kurumsal mesajları, konuşmaları, basın açıklamaları ve dernek faaliyetleri.</p>\n      \n      <div style=\"display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; width: 100%; max-width: 900px; margin: 0 auto;\">\n        <div style=\"background: rgba(255,255,255,0.06); padding: 22px 30px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); flex: 1; min-width: 180px; box-shadow: 0 10px 20px rgba(0,0,0,0.2);\">\n          <div style=\"font-family: 'Montserrat', sans-serif; font-size: 26px; font-weight: 800; color: #C9A84C; margin-bottom: 5px;\">Milli</div>\n          <div style=\"font-size: 12px; opacity: 0.8; font-weight: 500; text-transform: uppercase; letter-spacing: 1px;\">Şuurlu Duruş</div>\n        </div>\n        <div style=\"background: rgba(255,255,255,0.06); padding: 22px 30px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); flex: 1; min-width: 180px; box-shadow: 0 10px 20px rgba(0,0,0,0.2);\">\n          <div style=\"font-family: 'Montserrat', sans-serif; font-size: 26px; font-weight: 800; color: #C9A84C; margin-bottom: 5px;\">7/24</div>\n          <div style=\"font-size: 12px; opacity: 0.8; font-weight: 500; text-transform: uppercase; letter-spacing: 1px;\">Vefa ve Destek</div>\n        </div>\n        <div style=\"background: rgba(255,255,255,0.06); padding: 22px 30px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); flex: 1; min-width: 180px; box-shadow: 0 10px 20px rgba(0,0,0,0.2);\">\n          <div style=\"font-family: 'Montserrat', sans-serif; font-size: 26px; font-weight: 800; color: #C9A84C; margin-bottom: 5px;\">Ankara</div>\n          <div style=\"font-size: 12px; opacity: 0.8; font-weight: 500; text-transform: uppercase; letter-spacing: 1px;\">Genel Merkez</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div style=\"max-width: 1200px; margin: 60px auto 0; padding: 0 20px; width: 100%; box-sizing: border-box;\">\n    \n    <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; margin-bottom: 60px; width: 100%; box-sizing: border-box;\">\n      \n      <a href=\"https://yekpare.net/tr/vkd/haber/genel-baskanimiz-mustafa-ozdemir?siteId=7\" style=\"text-decoration: none; display: block; background: #fff; border: 1px solid #E2E8F0; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.02); transition: transform 0.3s ease;\">\n        <div style=\"height: 8px; background: #8C1A2E; width: 100%;\"></div>\n        <div style=\"padding: 35px 30px;\">\n          <div style=\"background: rgba(140, 26, 46, 0.08); width: 55px; height: 55px; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #8C1A2E; font-size: 22px; margin-bottom: 25px;\">\n            <i class=\"fa fa-user-check\"></i>\n          </div>\n          <h3 style=\"font-family: 'Montserrat', sans-serif; font-size: 19px; color: #0D1117; margin: 0 0 12px; font-weight: 700;\">Genel Başkanımız</h3>\n          <p style=\"color: #64748B; font-size: 14.5px; margin: 0 0 25px; line-height: 1.6;\">Genel Başkanımız Mustafa ÖZDEMİR'in özgeçmişi, milli meselelerdeki duruşu ve geleceğe yönelik mesajları.</p>\n          <div style=\"display: flex; justify-content: space-between; align-items: center; font-size: 13px; font-weight: 700; color: #8C1A2E; text-transform: uppercase; letter-spacing: 0.5px;\">\n            <span>Başkanı İncele</span> <i class=\"fa fa-arrow-right-long\"></i>\n          </div>\n        </div>\n      </a>\n\n      <a href=\"https://yekpare.net/tr/vkd/kategori/dernegimiz?siteId=7\" style=\"text-decoration: none; display: block; background: #fff; border: 1px solid #E2E8F0; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.02); transition: transform 0.3s ease;\">\n        <div style=\"height: 8px; background: #C9A84C; width: 100%;\"></div>\n        <div style=\"padding: 35px 30px;\">\n          <div style=\"background: rgba(201, 168, 76, 0.12); width: 55px; height: 55px; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #C9A84C; font-size: 22px; margin-bottom: 25px;\">\n            <i class=\"fa fa-users\"></i>\n          </div>\n          <h3 style=\"font-family: 'Montserrat', sans-serif; font-size: 19px; color: #0D1117; margin: 0 0 12px; font-weight: 700;\">Derneğimiz</h3>\n          <p style=\"color: #64748B; font-size: 14.5px; margin: 0 0 25px; line-height: 1.6;\">Vatan Kahramanları Derneği'nin kuruluş amaçları, tüzüğü, vizyonu ve şehit yakınları ile gazilerimize yönelik tüm çalışmaları.</p>\n          <div style=\"display: flex; justify-content: space-between; align-items: center; font-size: 13px; font-weight: 700; color: #C9A84C; text-transform: uppercase; letter-spacing: 0.5px;\">\n            <span>Derneğe Git</span> <i class=\"fa fa-arrow-right-long\"></i>\n          </div>\n        </div>\n      </a>\n\n      <a href=\"https://yekpare.net/tr/vkd/iletisim\" style=\"text-decoration: none; display: block; background: #fff; border: 1px solid #E2E8F0; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.02); transition: transform 0.3s ease;\">\n        <div style=\"height: 8px; background: #0D1117; width: 100%;\"></div>\n        <div style=\"padding: 35px 30px;\">\n          <div style=\"background: rgba(13, 17, 23, 0.06); width: 55px; height: 55px; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #0D1117; font-size: 22px; margin-bottom: 25px;\">\n            <i class=\"fa fa-address-book\"></i>\n          </div>\n          <h3 style=\"font-family: 'Montserrat', sans-serif; font-size: 19px; color: #0D1117; margin: 0 0 12px; font-weight: 700;\">İletişim Bilgileri</h3>\n          <p style=\"color: #64748B; font-size: 14.5px; margin: 0 0 25px; line-height: 1.6;\">Genel Merkezimizle irtibata geçmek, projelerimize destek sağlamak veya bilgi edinmek için resmi kanallarımız.</p>\n          <div style=\"display: flex; justify-content: space-between; align-items: center; font-size: 13px; font-weight: 700; color: #0D1117; text-transform: uppercase; letter-spacing: 0.5px;\">\n            <span>İletişime Geç</span> <i class=\"fa fa-arrow-right-long\"></i>\n          </div>\n        </div>\n      </a>\n\n    </div>\n\n    <div style=\"background: linear-gradient(135deg, #0D1117, #1E293B); border-left: 6px solid #C9A84C; border-radius: 16px; padding: 45px 40px; margin-bottom: 60px; box-sizing: border-box; box-shadow: 0 10px 25px rgba(0,0,0,0.05); text-align: center;\">\n      <p style=\"font-family: 'Playfair Display', serif; font-style: italic; font-size: 24px; color: #fff; margin-top: 0; margin-bottom: 15px; font-weight: 700; line-height: 1.4;\">\"Vatan uğruna can veren kahramanlarımızın hatırasını yaşatmak en kutlu vazifemizdir.\"</p>\n      <div style=\"font-family: 'Montserrat', sans-serif; font-size: 14px; color: #C9A84C; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;\">— Mustafa ÖZDEMİR, Vatan Kahramanları Derneği Genel Başkanı</div>\n    </div>\n\n    <div style=\"margin-bottom: 40px; border-left: 5px solid #8C1A2E; padding-left: 18px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px;\">\n      <div>\n        <h3 style=\"font-family: 'Montserrat', sans-serif; font-weight: 800; color: #0D1117; margin: 0; font-size: 24px; text-transform: uppercase; letter-spacing: 0.5px;\">Genel Başkan Yazıları</h3>\n        <p style=\"color: #64748B; margin: 5px 0 0; font-size: 14px;\">Milli şuur, vatanseverlik ve dernek vizyonuna ait en son kaleme alınan makaleler.</p>\n      </div>\n      <a href=\"https://yekpare.net/tr/vkd/kategori/dernegimiz?siteId=7\" style=\"color: #8C1A2E; font-weight: 700; font-size: 14px; text-decoration: none; text-transform: uppercase; letter-spacing: 0.5px;\">Tümünü Gör <i class=\"fa fa-arrow-right-long\" style=\"margin-left: 5px;\"></i></a>\n    </div>\n\n    <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 30px; margin-bottom: 60px; width: 100%; box-sizing: border-box;\">\n      \n      <div style=\"background: #fff; border-radius: 16px; border: 1px solid #E2E8F0; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.02); display: flex; flex-direction: column;\">\n        <div style=\"position: relative; height: 210px; background: #0D1117 url('https://images.unsplash.com/photo-1457369804613-52c61a468e7d?q=80&w=1000') center/cover;\">\n          <span style=\"position: absolute; top: 15px; left: 15px; background: #8C1A2E; color: #fff; font-size: 11px; font-weight: 700; padding: 5px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px;\">Birlik ve Beraberlik</span>\n        </div>\n        <div style=\"padding: 25px; flex: 1; display: flex; flex-direction: column; justify-content: space-between;\">\n          <div>\n            <h4 style=\"margin: 0 0 12px; font-family: 'Montserrat', sans-serif; font-size: 17px; font-weight: 700; color: #0D1117; line-height: 1.45;\">Kahramanlarımızın Emanetine Sahip Çıkmak</h4>\n            <p style=\"margin: 0 0 20px; font-size: 14px; color: #64748B; line-height: 1.6; text-align: justify;\">Gelişen dünyada ve zorlu coğrafyamızda köklerimizden kopmadan, şehit ve gazi ailelerimizin toplumsal yapımızdaki sarsılmaz yerini koruma kararlılığımız üzerine...</p>\n          </div>\n          <div style=\"display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: #94A3B8; border-top: 1px solid #F1F5F9; padding-top: 15px;\">\n            <span><i class=\"fa fa-calendar-days\" style=\"margin-right: 5px;\"></i> Başyazı</span>\n            <a href=\"https://yekpare.net/tr/vkd/haber/genel-baskanimiz-mustafa-ozdemir?siteId=7\" style=\"color: #8C1A2E; font-weight: 600; text-decoration: none;\">Devamını Oku <i class=\"fa fa-chevron-right\" style=\"font-size: 10px; margin-left: 2px;\"></i></a>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"background: #fff; border-radius: 16px; border: 1px solid #E2E8F0; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.02); display: flex; flex-direction: column;\">\n        <div style=\"position: relative; height: 210px; background: #0D1117 url('https://images.unsplash.com/photo-1516979187457-637abb4f9353?q=80&w=1000') center/cover;\">\n          <span style=\"position: absolute; top: 15px; left: 15px; background: #C9A84C; color: #0D1117; font-size: 11px; font-weight: 800; padding: 5px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px;\">Vefa Projeleri</span>\n        </div>\n        <div style=\"padding: 25px; flex: 1; display: flex; flex-direction: column; justify-content: space-between;\">\n          <div>\n            <h4 style=\"margin: 0 0 12px; font-family: 'Montserrat', sans-serif; font-size: 17px; font-weight: 700; color: #0D1117; line-height: 1.45;\">Toplumsal Dayanışma Ruhu ve Sivil Toplum Bilinci</h4>\n            <p style=\"margin: 0 0 20px; font-size: 14px; color: #64748B; line-height: 1.6; text-align: justify;\">Tarihin bizlere yüklediği misyonla, yardımlaşma ve vefa duygularının kurumsallaşması ve derneğimiz bünyesinde gerçekleştireceğimiz geniş çaplı projelerimiz...</p>\n          </div>\n          <div style=\"display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: #94A3B8; border-top: 1px solid #F1F5F9; padding-top: 15px;\">\n            <span><i class=\"fa fa-calendar-days\" style=\"margin-right: 5px;\"></i> Kurumsal Mesaj</span>\n            <a href=\"https://yekpare.net/tr/vkd/kategori/dernegimiz?siteId=7\" style=\"color: #C9A84C; font-weight: 700; text-decoration: none;\">Devamını Oku <i class=\"fa fa-chevron-right\" style=\"font-size: 10px; margin-left: 2px;\"></i></a>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    <section style=\"background: linear-gradient(135deg, #8C1A2E, #6E1222); color: #fff; padding: 50px 30px; text-align: center; border-radius: 20px; box-sizing: border-box; box-shadow: 0 10px 20px rgba(140, 26, 46, 0.1);\">\n      <h3 style=\"font-family: 'Montserrat', sans-serif; font-size: 24px; margin-top: 0; margin-bottom: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;\">Kurumsal İş Birliği ve İletişim</h3>\n      <p style=\"max-width: 700px; margin: 0 auto 25px; font-size: 15px; opacity: 0.85; font-weight: 300; line-height: 1.6;\">Resmi heyet görüşmeleri, kurumsal ziyaretler ve dernek ortak çalışma talepleriniz için başkanlık ofisi ile doğrudan irtibata geçebilirsiniz.</p>\n      \n      <div style=\"display: flex; justify-content: center; gap: 15px; flex-wrap: wrap;\">\n        <a href=\"https://yekpare.net/tr/vkd/iletisim\" style=\"background: #C9A84C; color: #0D1117; padding: 12px 35px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; box-shadow: 0 4px 10px rgba(201, 168, 76, 0.2);\">📬 Başkanlık Ofisine Yazın</a>\n        <a href=\"https://yekpare.net/tr/vkd/kategori/dernegimiz?siteId=7\" style=\"background: rgba(255, 255, 255, 0.1); color: #fff; padding: 12px 35px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 14px; border: 1px solid rgba(255, 255, 255, 0.2);\">Dernek Yapısı</a>\n      </div>\n    </section>\n\n  </div>\n</div>","enabled":true,"fullWidth":true}]}