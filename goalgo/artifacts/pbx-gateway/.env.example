# Yekpare PBX Gateway — SIP köprü + Asterisk AMI
PORT=3099

# Demo modu: gerçek SIP/AMI olmadan geliştirme
PBX_DEMO_MODE=true

# JWT (api-server PBX_JWT_SECRET ile uyumlu olmalı)
PBX_JWT_SECRET=dev-pbx-secret-change-me

# Goalgo API (opsiyonel senkron)
API_SERVER_URL=http://127.0.0.1:3000

# WebSocket — tarayıcı softphone iskeleti
PBX_WS_PATH=/ws

# SIP trunk köprüsü (Faz 2)
# PBX_SIP_TRUNK_HOST=sip.provider.com

# Asterisk AMI (FreePBX / Issabel)
# ASTERISK_AMI_HOST=10.0.0.5
# ASTERISK_AMI_PORT=5038
# ASTERISK_AMI_USER=goalgoami
# ASTERISK_AMI_PASS=guclu-sifre
