# Required in production (min 16 chars). Used for express-session + JWT signing in some routes.
SESSION_SECRET=

# Yönetim paneli girişi. Bu değerler yalnızca API servisinde tutulur; frontend/Vercel bundle'a eklenmez.
# POST /api/members/admin-panel-session için gerekli.
ADMIN_PANEL_USERNAMES=
ADMIN_PANEL_PASSWORD=

# İsteğe bağlı: tohum / migrate / harita senkronu gibi POST uçlarında panel oturumu yerine başlık X-Yekpare-Admin-Secret ile yetkilendirme (CI / sunucu içi script).
# ADMIN_MAINTENANCE_SECRET=

# Demo seed (production'da varsayılan kapalı). Canlıda demo veri yüklemek için ENABLE_DEMO_SEED=1 gerekir.
# ENABLE_DEMO_SEED=1
# VENDOR_APPROVAL_TEMP_PASSWORD=   # Sağlayıcı onay e-postasındaki geçici şifre (boş = rastgele)
# GELIVER_DEMO_PASSWORD=           # Geliver demo mağaza seed (dev'de varsayılan; prod'da env zorunlu)
# PBX_DEMO_AGENT_PASSWORD=         # PBX demo temsilci seed
# TRANSPORT_DEMO_VENDOR_PASSWORD=  # Demo ulaşım işletmesi seed
# TRANSPORT_DEMO_COURIER_PASSWORD= # Demo kurye seed
# Üretimde daha önce sabit şifrelerle oluşturulmuş hesapları (yekpare, agent123, GeliverDemo2026!) rotate edin.

# PostgreSQL (örnek: postgresql://user:pass@host:5432/yekpare)
DATABASE_URL=
# PG_POOL_MAX=20
# PG_POOL_IDLE_TIMEOUT_MS=30000
# PG_POOL_CONNECTION_TIMEOUT_MS=10000

# Haberler için ayrı Postgres (Railway'de ikinci PostgreSQL servisi — bkz. docs/HABER_AYRI_DB_KURULUM.md)
# NEWS_DATABASE_URL=
# NEWS_DB_READ=main
# NEWS_DB_WRITE=main

# Yektube için ayrı Postgres (bkz. docs/YEKTUBE_AYRI_DB_KURULUM.md)
# YEKTUBE_DATABASE_URL=
# YEKTUBE_DB_READ=yektube
# YEKTUBE_DB_WRITE=yektube
# SKIP_YEKTUBE_DB_MIGRATE=1
# SKIP_YEKTUBE_DATA_MIGRATE=1
# SKIP_NEWS_DB_MIGRATE=1
# SKIP_NEWS_DATA_MIGRATE=1

# Production CORS: virgülle tam kökenler (https://yekpare.net,https://www.yekpare.net).
# HM editör + mağaza özel alanları veritabanından otomatik eklenir; portal kökleri varsayılan listede.
# Geçici tanılama: RELAX_CORS_IN_PRODUCTION=1 (üretimde kalıcı bırakmayın).
# CORS_ALLOWED_ORIGINS=

# Stripe Checkout — HM kurumsal bağış ve mevcut ödeme akışları için.
# Alternatif olarak panelde Genel Ayarlar > Stripe alanındaki DB kaydı kullanılabilir.
STRIPE_SECRET_KEY=
# Webhook bağış checkout redirect MVP'si için zorunlu değil; sipariş/delivery webhook'larında gerekir.
# STRIPE_WEBHOOK_SECRET=

# Migrasyon: production `start` önce db-migrate çalıştırır. Acil: SKIP_DB_MIGRATE=1 — şema bu koşuda atlanır.
# Elle güncelleme: DATABASE_URL dolu iken `pnpm run db:migrate` (yerel veya Railway shell).
# SKIP_DB_MIGRATE=

# Geliver test gönderileri (SDK shipments.test=true). Canlı etiket için kullanmayın.
# GELIVER_TEST_SHIPMENTS=1
# Geliver webhook imza/paylaşımlı secret — POST /api/providers/geliver/webhook (HMAC X-Signature veya X-Geliver-Webhook-Secret).
# GELIVER_WEBHOOK_SECRET=

# Gemini (AI İçerik Robotu yedek + Yekpare AI + /ara internet araması).
# Anahtar: Genel Ayarlar → Entegrasyonlar → gemini_api_key (site_settings) veya GEMINI_API_KEY env.
# Model varsayılan: gemini-3.1-flash-lite (GEMINI_MODEL ile değiştirilebilir).
# GEMINI_SEARCH_ENABLED=1 — Google Search grounding (varsayılan açık; 0/false ile kapatılır).
# GEMINI_TIMEOUT_MS=18000 — API zaman aşımı (ms).
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_API_KEY=

# Google Places / Maps — sunucu (Text Search, foto proxy, admin kazıyıcı, Keşfet navigasyon Routes API). Referrer kısıtlı tarayıcı anahtarı burada çalışmaz.
# Cloud Console’da “Routes API” etkin olmalı (ComputeRoutes). Kota dolunca Keşfet otomatik OSRM’e düşer.
# GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_SERVER_KEY=

# Yektube SEO — yabancı video başlıkları Google Translate ile (Gemini değil).
# Cloud Console'da Cloud Translation API etkin olmalı.
# GOOGLE_TRANSLATE_API_KEY=  (veya yukarıdaki Maps/Places sunucu anahtarı)
# GOOGLE_TRANSLATE_TIMEOUT_MS=12000

# Günlük trendler (/api/search/trends, /api/trends/daily) — varsayılan: Google Trends RSS (anahtar gerekmez, geo=TR).
# GOOGLE_TRENDS_GEO=TR
# İsteğe bağlı SerpAPI yedek: SERPAPI_API_KEY=

# NASA FIRMS — Keşfet/Haritalar canlı orman yangını sıcak nokta katmanı.
# Ücretsiz MAP_KEY: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# NASA_FIRMS_MAP_KEY=
# FIRMS_MAP_KEY=

# CollectAPI — nöbetçi eczane proxy (/map/duty-pharmacies), uçak ve otobüs fiyatı yedek/birincil kaynak.
# https://collectapi.com → profil → API token. Paketler: health (Nöbetçi Eczane), travel (Seyahat / otobüs + uçak).
# İsteğe bağlı özel uç nokta: COLLECTAPI_TRAVEL_BUS_PATH=travel/getBusway
# Yalnızca Railway / api-server ortam değişkeni; panelden girilmez.
# COLLECTAPI_KEY=

# Süper Lig / 1. Lig puan + fikstür — GET /api/public/superlig/puan | /fikstur
# https://tff.kkerem.com/ — aynı TFF_SUPERLIG_API_KEY ile; 1. Lig için `lig=1lig` query param.
# TFF_SUPERLIG_API_KEY=
# SUPERLIG_API_KEY=   # alternatif env adı

# Etkinlik.io V2 API — /turizm/etkinlik etkinlik listesi (yayıncı ağı başvurusu gerekir).
# https://etkinlik.io/api-bilgi — isteklerde X-Etkinlik-Token başlığı kullanılır.
# Etkinlik.io yayıncı ağı API anahtarı (X-Etkinlik-Token)
# ETKINLIK_IO_API_KEY=
# ETKINLIK_IO_TOKEN=   # alternatif env adı (ETKINLIK_IO_KEY, ETKINLIK_API_KEY, ETKINLIK_TOKEN da kabul edilir)
# Uçlar: GET /api/travel/events/search | /taxonomy | /categories | /formats | /status | /:idOrSlug
# Teşhis: GET /api/healthz → integrations.etkinlikIo (token sızdırmaz)

# Yektube — embed kapalı native akış (Railway api-server)
# PO Token + visitor data: InnerTube WEB istemcisi (403 / LOGIN_REQUIRED azaltır)
# YOUTUBE_PO_TOKEN=
# YOUTUBE_VISITOR_DATA=
# TR / residential egress (googlevideo + youtubei istekleri)
# YOUTUBE_EGRESS_PROXY_URL=http://user:pass@host:port
# YOUTUBE_EGRESS_PROXY_URLS=http://proxy1:8080,http://proxy2:8080
# youtubei.js player-script önbellek dizini (P2-N6)
# YOUTUBE_PLAYER_CACHE_DIR=/tmp/yektube-youtubei-player-cache

# Yektube — web push (VAPID; abonelik kaydı Hesabım → Ayarlar)
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_CONTACT=mailto:support@yektube.com

# Yekpare PBX — agent portalı (/pbx); Asterisk YOK — pbx-gateway SIP köprüsü (Faz 2)
# Bkz. docs/PBX_YOL_HARITASI.md
# PBX_BRIDGE_URL=http://127.0.0.1:3099
# PBX_BRIDGE_WS_URL=ws://127.0.0.1:3099/ws
# PBX_JWT_SECRET=                        # Üretimde zorunlu, min 16 karakter (temsilci JWT + AI Call şifreleme)
# PBX_AGENTS=agent1:demo123:Ayşe Yılmaz:101,demo:demo123:Demo Agent:100

# Yekpare AI Call — varsayılan yerel mod (Railway'de USE_NATIVE_AI_CALL eklemeniz gerekmez)
# USE_NATIVE_AI_CALL=true   # varsayılan; yalnızca legacy AgentLabs için false
# AGENTLABS_URL=https://call.example.com
# AGENTLABS_API_KEY=eyJ...   # AgentLabs servis hesabı JWT
# AGENTLABS_SERVICE_EMAIL=
# AGENTLABS_SERVICE_PASSWORD=
# AGENTLABS_HEALTH_PATH=/api/health

# Site posta kutusu — bilgi@yekpare.net (admin: /admin/posta-ve-duyurular)
# DNS/MX domain sağlayıcısında; Vercel'de değil. Bkz. docs/MAILBOX_BILGI_SETUP.md
# SITE_MAILBOX_ADDRESS=bilgi@yekpare.net
# SMTP_HOST=smtp.zoho.eu
# SMTP_PORT=587
# SMTP_USER=bilgi@yekpare.net
# SMTP_PASS=
# SMTP_FROM=Yekpare <bilgi@yekpare.net>
# IMAP_HOST=imap.zoho.eu
# IMAP_PORT=993
# IMAP_USER=bilgi@yekpare.net
# IMAP_PASS=
# SITE_MAILBOX_BOOTSTRAP=1
# SITE_MAILBOX_AUTO_SYNC=1
# SITE_MAILBOX_AUTO_SYNC_MS=300000

# Firebase Admin (pick ONE approach)
# 1) Path to a service account JSON file on the server (not in git):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# 2) Full JSON in one line (Vercel / CI):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# 3) Separate fields:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Yekpare Haritalar Firebase backend adapter
# disabled: mevcut Postgres backend kullanılır (varsayılan)
# mirror: Postgres kaynak kalır; saved places / user drafts / share states Firestore'a yansıtılır
# firestore: bu küçük kullanıcı harita durumları Firestore'dan okunur, hata halinde Postgres'e düşer
# YEKPARE_MAP_FIREBASE_BACKEND=disabled
# YEKPARE_MAP_FIREBASE_COLLECTION_PREFIX=yekpare_maps
