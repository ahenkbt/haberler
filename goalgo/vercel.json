      "has": [{ "type": "host", "value": "yektube.com" }],
      "destination": "/yektube-v2/index.html"
    },
    {
      "source": "/yp/:path((?!.*\\.).*)",
      "has": [{ "type": "host", "value": "yektube.com" }],
      "destination": "/yektube-v2/index.html"
    },
    {
