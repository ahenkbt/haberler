# Kopyalayın: bu dosyayı `goalgo/.env` olarak kaydedin (git’e eklenmez).
# Canlı site örneği: https://turknet.app — API aynı origin veya alt alan adında olabilir.

# PostgreSQL (zorunlu — migration ve API için)
# Aşağıdaki satır ÖRNEKTİR: kullanici / sifre / yekpare kısımlarını kendi Postgres kullanıcı, parola ve veritabanı adınızla değiştirin.
# Yerelde Postgres yoksa Docker: `docker run -e POSTGRES_PASSWORD=... -p 5432:5432 postgres:16` sonra CREATE DATABASE yekpare;
DATABASE_URL=postgresql://kullanici:sifre@localhost:5432/yekpare

# Haberler için ayrı Postgres (isteğe bağlı — Railway'de ikinci PostgreSQL servisi)
# NEWS_DATABASE_URL=
# NEWS_DB_READ=main
# NEWS_DB_WRITE=main
# Dual-write testi: NEWS_DB_WRITE=dual — okumayı haber DB'ye almak: NEWS_DB_READ=news

# Migrasyon: api-server `start` ile önce `scripts/db-migrate.mjs` çalışır (Drizzle, goalgo/lib/db/migrations).
# Acil durumda deploy’u migration’a takılmadan açmak için: SKIP_DB_MIGRATE=1
# Bu açıkken şema güncellenmez. Sonra ya değişkeni kaldırıp yeniden deploy edin ya da elle:
#   cd goalgo && pnpm run db:migrate
#   (veya: cd goalgo/artifacts/api-server && pnpm run db:migrate)
# (Railway: Variables’tan SKIP kaldırın veya shell’de aynı komut + DATABASE_URL.)

# SKIP_DB_MIGRATE=

# Oturum (üretimde min. 16 karakter)
SESSION_SECRET=cok_gizli_bir_anahtar_buraya_yazin

# İsteğe bağlı: Firebase, Google Maps, OpenAI, Stripe…
# Gemini (haber AI yedek + Yekpare AI + /ara internet araması): Yönetim → Genel Ayarlar → geminiApiKey (DB) veya GEMINI_API_KEY.
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_SEARCH_ENABLED=1
# Premium Checkout webhook: önce `payment_settings.stripe_webhook_secret` (panel); yoksa bu env (ör. Replit).
# STRIPE_WEBHOOK_SECRET=whsec_...
# FIREBASE_PROJECT_ID=
#
# Google — sunucu (Veri Kazıyıcı / Places Text Search / Keşfet navigasyon Routes API). Yerelde goalgo/.env; canlıda Railway Variables.
# Tarayıcı (Maps JS) anahtarı Genel Ayarlar → Harita’dadır; bu satır sunucu istekleri içindir. Routes API projede açık olmalı; kota dolunca OSRM yedek.
# GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_SERVER_KEY=

# Yekpare AI Call — ayrı Node deploy (AgentLabs v5); Yekpare API vekil + Vercel /call-center-app vekili.
# Railway (API): AGENTLABS_URL + AGENTLABS_API_KEY (veya servis e-posta/şifre)
# Vercel (Production): aynı AGENTLABS_URL — Edge middleware tam SPA vekili için
# AGENTLABS_URL=https://call.turknet.app
# AGENTLABS_API_KEY=

# Klasik PBX (agent portal /pbx, admin /admin/pbx) — api-server gömülü demo DB; isteğe bağlı harici AMI gateway.
# PBX_GATEWAY_URL=http://127.0.0.1:3100
# PBX_JWT_SECRET=   # Üretimde zorunlu, min 16 karakter (api-server + pbx-gateway aynı değer)
# Demo agent seed (ilk migrate): ayse / agent123 — POST /api/pbx/admin/seed-demo ile de yüklenebilir

# Menü içe aktarma (Getir/Yemeksepeti): Railway IP 405 alırsa Vercel edge vekili kullanılır.
# Aynı rastgele değeri hem Vercel hem Railway ortamına yazın.
# EDGE_FETCH_SECRET=
# EDGE_FETCH_ORIGIN=https://turknet.app

# CollectAPI — nöbetçi eczane (Keşfet/Haritalar), uçak fiyatı yedek ve otobüs sefer araması.
# https://collectapi.com hesabı → profil → API token. Abonelik: health (Nöbetçi Eczane) + travel (Seyahat / uçak + otobüs).
# COLLECTAPI_KEY=
